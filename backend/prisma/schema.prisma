generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Scheme {
  id              String   @id @default(uuid())
  name            String
  poolAmount      Int
  numberOfMembers Int      @default(20)
  numberOfMonths  Int      @default(20)
  paymentSchedule String
  payoutSchedule  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  pools           Pool[]
}

model Pool {
  id             String          @id @default(uuid())
  name           String
  schemeId       String
  startDate      DateTime
  status         String          @default("UPCOMING")
  currentMonth   Int             @default(1)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  enrollments    Enrollment[]
  scheme         Scheme          @relation(fields: [schemeId], references: [id])
  potAssignments PotAssignment[]
}

model Member {
  id               String       @id @default(uuid())
  fullName         String
  phone            String       @unique
  alternatePhone   String?
  address          String
  aadhaarRef       String
  panRef           String
  nomineeName      String
  nomineePhone     String
  status           String       @default("ACTIVE")
  riskLevel        String?
  riskReason       String?
  riskCalculatedAt DateTime?
  creditBalance    Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  enrollments      Enrollment[]
}

model Enrollment {
  id               String          @id @default(uuid())
  memberId         String
  poolId           String
  slotNumber       Int
  potReceived      Boolean         @default(false)
  potReceivedMonth Int?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  member           Member          @relation(fields: [memberId], references: [id])
  pool             Pool            @relation(fields: [poolId], references: [id])
  payments         Payment[]
  potAssignments   PotAssignment[]

  @@unique([memberId, poolId])
  @@unique([poolId, slotNumber])
}

model Payment {
  id           String     @id @default(uuid())
  enrollmentId String
  month        Int
  amountDue    Int        @default(0)
  amountPaid   Int        @default(0)
  lateFee      Int        @default(0)
  paymentMode  String     @default("CASH")
  status       String     @default("PAID")
  notes        String?
  paidAt       DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])

  @@unique([enrollmentId, month])
}

model PotAssignment {
  id           String     @id @default(uuid())
  poolId       String
  month        Int
  enrollmentId String
  potAmount    Int
  paymentMode  String     @default("BANK")
  notes        String?
  assignedAt   DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  pool         Pool       @relation(fields: [poolId], references: [id])

  @@unique([poolId, month])
}

model AppSettings {
  id            String   @id @default("singleton")
  reminderDay   Int      @default(5)
  autoReminders Boolean  @default(false)
  companyName   String   @default("ChitFund Pro")
  ownerPhone    String   @default("")
  updatedAt     DateTime @updatedAt
}

model NotificationLog {
  id             String   @id @default(uuid())
  memberName     String
  phone          String
  messageContent String
  status         String   @default("SENT")
  errorMessage   String?
  sentAt         DateTime @default(now())
}

model ScheduledReminder {
  id              String   @id @default(cuid())
  targetType      String
  targetId        String?
  targetName      String?
  dayOfMonth      Int
  messageOverride String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
}
